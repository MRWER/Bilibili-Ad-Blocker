{
  "manifest_version": 3,
  "name": "B站评论区广告一键清剿",
  "version": "1.0",
  "description": "识别并一键举报、拉黑B站评论区中可疑的广告号。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://api.bilibili.com/*",
    "https://space.bilibili.com/*",
    "https://www.bilibili.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "B站广告清剿"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["detector.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}