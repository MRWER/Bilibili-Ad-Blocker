{
  "manifest_version": 3,
  "name": "B站评论区广告一键清剿",
  "version": "1.1.3",
  "description": "识别并一键拉黑B站评论区中的广告号，内置机器学习模型持续优化。",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "https://*.bilibili.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "B站广告清剿"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/video/*","https://www.bilibili.com/opus/*","https://t.bilibili.com/*"],
      "js": ["detector.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}